@inherits LayoutComponentBase
@using MudBlazor
@using BlazorApp.Services
@inject SupabaseClientService SupabaseService
@inject NavigationManager Nav

<MudLayout>

    <!-- Top App Bar -->
    <MudAppBar Elevation="2"
               Class="px-2"
               Style="background-color:lavender; color:black;">

        <MudText Typo="Typo.h6">
            WeatherApp
        </MudText>

        <MudSpacer />

        @if (SupabaseService.Client.Auth.CurrentSession == null)
        {
            <MudButton Href="/login"
            Variant="Variant.Filled"
                       Color="Color.Secondary"
                       Class="ms-2"
                       
                       StartIcon="@Icons.Material.Filled.Login">
                Login
            </MudButton>

            <MudButton Href="/register"
                       Variant="Variant.Filled"
                       Color="Color.Secondary"
                       Class="ms-2"
                       StartIcon="@Icons.Material.Filled.PersonAdd">
                Register
            </MudButton>
        }
        else
        {
            var email = SupabaseService.Client.Auth.CurrentSession.User.Email;

            <MudMenu Icon="@Icons.Material.Filled.AccountCircle"
                     Color="Color.Inherit"
                     AnchorOrigin="Origin.BottomRight"
                     TransformOrigin="Origin.TopRight">

                <MudText Class="px-4 pt-3"
                         Typo="Typo.subtitle2"
                         Style="font-weight:600;">
                    @email
                </MudText>

                <MudDivider Class="my-2" />

                <MudMenuItem Href="/profile">
                    My Profile
                </MudMenuItem>

                <MudMenuItem OnClick="Logout">
                    Logout
                </MudMenuItem>

            </MudMenu>
        }

    </MudAppBar>

    <!-- Page Content -->
    <MudMainContent Class="p-4">
        @Body
    </MudMainContent>

</MudLayout>

@code {
    private async Task Logout()
    {
        await SupabaseService.Client.Auth.SignOut();
        Nav.NavigateTo("/login", true);
    }
}